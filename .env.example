# AI CV Optimizer — Environment Variables
# Copy this file to .env and fill in your chosen provider's values.
# Only ONE provider section needs to be configured.

# ── Which AI provider to use ──────────────────────────────────────
# Options: gemini | openai | cloudflare
AI_PROVIDER=gemini

# ── Generation settings (apply to all providers) ──────────────────
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=8192

# ── Google Gemini (AI_PROVIDER=gemini) ───────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=paste_your_google_ai_api_key_here
GOOGLE_MODEL_NAME=gemini-2.5-flash

# ── OpenAI-compatible (AI_PROVIDER=openai) ────────────────────────
# Works with: Ollama, LM Studio, vLLM, OpenAI, Groq, Together AI
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL_NAME=llama3.1

# ── Cloudflare Workers AI (AI_PROVIDER=cloudflare) ────────────────
# Get credentials at: https://dash.cloudflare.com/
# API token needs "Workers AI" permission.
#
# VALID model names (verify at https://developers.cloudflare.com/workers-ai/models/):
#   @cf/meta/llama-3.1-8b-instruct        ← fast, free tier (recommended)
#   @cf/meta/llama-3.1-70b-instruct       ← best quality
#   @cf/mistral/mistral-7b-instruct-v0.2  ← alternative
#   @cf/google/gemma-7b-it                ← Google's Gemma
#
# CF_ACCOUNT_ID=your_cloudflare_account_id_here
# CF_API_TOKEN=your_cloudflare_api_token_here
# CF_MODEL_NAME=@cf/meta/llama-3.1-8b-instruct
